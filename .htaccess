# S.T.R.In.G production Apache rules
# Keep this file conservative: strong defaults without breaking Cal.com, Google tags, or inline static-page scripts.

Options -Indexes
ServerSignature Off

DirectoryIndex index.html index.php

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS in production.
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1)(:\d+)?$ [NC]
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # Canonical host: non-www.
  RewriteCond %{HTTP_HOST} ^www\.stringlab\.org$ [NC]
  RewriteRule ^ https://stringlab.org%{REQUEST_URI} [R=301,L]

  # Canonical homepage.
  RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
  RewriteRule ^index\.html$ / [R=301,L]

  # Canonical extensioned page URLs to extensionless URLs.
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.(html|php)[\s?] [NC]
  RewriteCond %1 !^index$ [NC]
  RewriteRule ^ %1 [R=301,L]

  # Hide .html extension.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]

  # Hide .php extension.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.php -f
  RewriteRule ^(.+?)/?$ $1.php [L]

  # Block private, legacy, development, and backup paths.
  RewriteRule (^|/)(\.git|\.svn|\.hg|\.local|node_modules|vendor|storage|old[[:space:]]website)(/|$) - [F,L,NC]
  RewriteRule (^|/)(composer\.(json|lock)|package(-lock)?\.json|pnpm-lock\.yaml|yarn\.lock|\.env.*|.*\.(bak|backup|old|orig|save|sql|sqlite|log|ini|sh))$ - [F,L,NC]

  # The PHP endpoint may be posted to, but PHP internals should not be browsed directly.
  RewriteCond %{REQUEST_URI} !^/php/send_email\.php$ [NC]
  RewriteRule ^php/ - [F,L,NC]
</IfModule>

<FilesMatch "(^\.|composer\.(json|lock)|package(-lock)?\.json|pnpm-lock\.yaml|yarn\.lock|\.env.*|.*\.(bak|backup|old|orig|save|sql|sqlite|log|ini|sh))$">
  Require all denied
</FilesMatch>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-XSS-Protection "0"
  Header always set Permissions-Policy "accelerometer=(), autoplay=(), camera=(), encrypted-media=(), fullscreen=(self), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), midi=(), payment=(), usb=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" "expr=%{HTTPS} == 'on'"

  # Keep a permissive-enough CSP for current inline JS plus Google/Cal embeds while still narrowing obvious attack surface.
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self' https://cal.com https://app.cal.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://app.cal.com https://cal.com; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://www.google.com https://www.gstatic.com https://app.cal.com https://cal.com; connect-src 'self' https://www.google-analytics.com https://www.googletagmanager.com https://www.google.com https://www.gstatic.com https://app.cal.com https://cal.com; frame-src 'self' https://cal.com https://app.cal.com https://www.google.com"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/json "access plus 1 hour"
  ExpiresByType application/xml "access plus 1 day"
  ExpiresByType text/xml "access plus 1 day"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|mjs|png|jpe?g|gif|webp|avif|svg|ico|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html?|xml|txt|json)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>

ErrorDocument 404 /404.html
